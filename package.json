{
  "name": "mico360-dolidesk",
  "version": "0.2.2",
  "description": "MICO360 DoliDesk — a desktop client for the Dolibarr ERP/CRM API",
  "author": "MICO360",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c blue,green \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "icons": "node scripts/make-icons.mjs",
    "start": "cross-env NODE_ENV=production electron .",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.47",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.mico360.dolidesk",
    "productName": "MICO360 DoliDesk",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon.ico",
    "publish": [
      {
        "provider": "github",
        "owner": "mico360om",
        "repo": "MICO360-DoliDesk"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
